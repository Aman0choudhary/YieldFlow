# YieldFlow MAINNET env template — DO NOT apply until you explicitly approve deploy
# Copy values into Vercel only after contracts are deployed and smoke-tested with tiny amounts.

YIELDFLOW_ALLOWED_ORIGIN=https://yieldflow-frontend.vercel.app
YIELDFLOW_RPC_URL=https://mainnet.sorobanrpc.com
YIELDFLOW_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
YIELDFLOW_NETWORK_LABEL=stellar-mainnet

# Deployer / employer (prefer dedicated mainnet identity, NOT testnet yieldflow-deployer)
YIELDFLOW_PUBLIC_KEY=G...MAINNET_EMPLOYER...
# Prefer hardware/wallet-signed deposits long-term. Hot signer is a launch risk.
YIELDFLOW_SIGNER_SECRET=S...MAINNET_ONLY_IF_YOU_ACCEPT_HOT_KEY_RISK...

# Filled after deploy-mainnet.ps1
YIELDFLOW_VAULT_CONTRACT_ID=C...
YIELDFLOW_STREAMING_CONTRACT_ID=C...
YIELDFLOW_BLEND_POOL_ID=C...confirmed_usdc_pool...
YIELDFLOW_TOKEN_CONTRACT_ID=CCW67TSZV3SSS2HXMBQ5JFGCKJNXKZM7UQUWUZPUTHXSTZLEO7SJMI75

# DeFindex mainnet
YIELDFLOW_DEFINDEX_VAULT_ID=CA2FIPJ7U6BG3N7EOZFI74XPJZOEOD4TYWXFVCIO5VDCHTVAGS6F4UKK
YIELDFLOW_DEFINDEX_STRATEGY_ID=CDB2WMKQQNVZMEBY7Q7GZ5C7E7IAFSNMZ7GGVD6WKTCEWK7XOIAVZSAP
YIELDFLOW_DEFINDEX_FACTORY_ID=CDKFHFJIET3A73A2YN4KV7NSV32S6YGQMUFH3DNJXLBWL4SKEGVRNFKI

# Passkey RP must stay production domain
YIELDFLOW_RP_ID=yieldflow-frontend.vercel.app
YIELDFLOW_RP_ORIGIN=https://yieldflow-frontend.vercel.app
YIELDFLOW_SESSION_SECRET=GENERATE_LONG_RANDOM_STRING

# Employee allowlist (comma-separated G... addresses)
YIELDFLOW_EMPLOYEE_ADDRESS=G...
YIELDFLOW_EMPLOYEE_ALLOWLIST=G...
